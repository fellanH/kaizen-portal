{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "kaizen-portal",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "vars": {
    "ADMIN_API_KEY": ""
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "kaizen-portal"
    }
  ]
}
